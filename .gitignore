# Ignore everything by default
*

# --- Whitelist: only the ingestion pipeline files are tracked ---

# Root docs
!README.md
!MERGE_GUIDE.md
!WORK_PLAN.md
!PATCHES.md
!CLAUDE_HANDOVER.md
!.gitignore

# Handover and email drafts
!JULY/
!JULY/HANDOVER-13-July-2026.md
!JULY/OOO-email-draft.md

# Ingestion scripts (the new files)
!scripts/
!scripts/**
scripts/**/__pycache__/
scripts/**/*.pyc

# Test fixtures and results
!tests/
!tests/**

# Architecture docs
!docs/
!docs/**

# Path B — Azure Function (server side). Source only.
!azure/
!azure/**
# Vendored parsers are a build artefact (copied from scripts/parsers at deploy)
azure/**/parsers/
# Azure Functions local secrets / build output
azure/**/local.settings.json
azure/**/.python_packages/
azure/**/bin/
azure/**/obj/

# Exclude secrets and large binaries everywhere
**/*.env
**/*.env.local
**/.env
**/notion_toke*
**/*.pdf
**/*.pptx
**/*.docx
**/*.xlsx
**/*.xls
**/*.pyc
**/__pycache__/
**/*.db
**/*.sqlite
