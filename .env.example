# IG Control Tower — environment template.
# Copy to `.env` at the repo root and fill in. `.env` is gitignored — never commit it.
# Real environment variables always take precedence over .env (see scripts/db/_envload.py).

# --- Azure Storage (Path B + db_sync) ---
# Portal: Storage account > Access keys > Connection string. Enables:
#   - Path B: the document-parser Function and _download_azure_fragments client side
#   - db_sync.py push/pull/status (Azure Table mirror)
#   - the Group 6 integration tests (pytest --run-integration)
AZURE_STORAGE_CONNECTION_STRING=

# Alternative to the connection string: least-privilege SAS (db_sync supports either)
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_TABLE_SAS=

# --- Notion (downstream stages; being phased out, optional here) ---
# NOTION_COMPANY_DB_ID=
# NOTION_NOTES_DB_ID=
# NOTION_PEOPLE_DB_ID=

# --- Local SQLite (optional override; defaults to ~/.claude/data/ig-control-tower.db) ---
# IG_CONTROL_TOWER_DB_PATH=
